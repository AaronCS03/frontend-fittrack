<%- include('partials/header', { title, API_BASE }) %>
<%
const page = 'dashboard';
%>

<%- include('partials/navbar', { page }) %>

<!-- Main Wrapper -->
<div class="main-wrapper">

  <!-- Top Navbar -->
  <header class="top-navbar">
    <button class="hamburger-btn" id="hamburgerBtn">
      <i class="bi bi-list"></i>
    </button>
    <span class="navbar-title">Dashboard</span>

    <div class="navbar-search">
      <i class="bi bi-search search-icon"></i>
      <input type="text" class="search-input" id="searchInput" placeholder="Search activities..." />
    </div>

    <div class="navbar-actions">
      <a href="/activities/create" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i>
        <span>Log Activity</span>
      </a>
    </div>
  </header>

  <!-- Page Content -->
  <main class="page-content" data-page="dashboard">

    <!-- Page Header -->
    <div class="page-header fade-in-up">
      <h1 class="page-title">Your Fitness Overview</h1>
      <p class="page-subtitle">Track progress, crush goals, stay consistent.</p>
    </div>

    <!-- Stat Cards -->
    <div class="stat-grid stagger-children">
      <div class="stat-card stat-card-green">
        <div class="stat-icon stat-icon-green"><i class="bi bi-lightning-charge-fill"></i></div>
        <div class="stat-label">Total Activities</div>
        <div class="stat-value" id="statTotal">—</div>
        <div class="stat-change"><i class="bi bi-arrow-up-short"></i> All time</div>
      </div>
      <div class="stat-card stat-card-blue">
        <div class="stat-icon stat-icon-blue"><i class="bi bi-fire"></i></div>
        <div class="stat-label">Calories Burned</div>
        <div class="stat-value" id="statCalories">—</div>
        <div class="stat-change"><i class="bi bi-arrow-up-short"></i> kcal total</div>
      </div>
      <div class="stat-card stat-card-purple">
        <div class="stat-icon stat-icon-purple"><i class="bi bi-clock-fill"></i></div>
        <div class="stat-label">Total Duration</div>
        <div class="stat-value" id="statDuration">—</div>
        <div class="stat-change"><i class="bi bi-arrow-up-short"></i> minutes logged</div>
      </div>
      <div class="stat-card stat-card-orange">
        <div class="stat-icon stat-icon-orange"><i class="bi bi-bar-chart-line-fill"></i></div>
        <div class="stat-label">Activity Types</div>
        <div class="stat-value" id="statTypes">—</div>
        <div class="stat-change"><i class="bi bi-arrow-up-short"></i> unique types</div>
      </div>
    </div>

    <!-- Charts -->
    <div class="charts-grid">
      <div class="chart-card fade-in-up">
        <div class="section-header" style="margin-bottom:20px;">
          <h3 class="section-title">Weekly Activity</h3>
          <span style="font-size:12px;color:var(--text-muted);">Last 7 days</span>
        </div>
        <canvas id="weeklyChart"></canvas>
      </div>
      <div class="chart-card fade-in-up">
        <div class="section-header" style="margin-bottom:20px;">
          <h3 class="section-title">By Type</h3>
        </div>
        <canvas id="typeChart"></canvas>
      </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar fade-in-up">
      <span class="filter-label">Filter:</span>
      <div class="filter-chips">
        <button class="filter-chip active" data-type="all">All</button>
        <button class="filter-chip" data-type="running">🏃 Running</button>
        <button class="filter-chip" data-type="cycling">🚴 Cycling</button>
        <button class="filter-chip" data-type="gym">🏋️ Gym</button>
        <button class="filter-chip" data-type="swimming">🏊 Swimming</button>
        <button class="filter-chip" data-type="yoga">🧘 Yoga</button>
        <button class="filter-chip" data-type="hiking">🥾 Hiking</button>
      </div>
      <select class="filter-select" id="filterSelect">
        <option value="date-desc">Newest First</option>
        <option value="date-asc">Oldest First</option>
        <option value="calories">Most Calories</option>
        <option value="duration">Longest Duration</option>
      </select>
    </div>

    <!-- Activity Cards Grid -->
    <div class="section-header">
      <h2 class="section-title">Activity Cards</h2>
    </div>

    <div id="activitiesGrid" class="activities-grid"></div>

    <!-- Empty State -->
    <div id="emptyState" class="empty-state" style="display:none;">
      <div class="empty-icon">🏃</div>
      <h3 class="empty-title">No activities yet</h3>
      <p class="empty-desc">Start logging your workouts to see them here.</p>
      <a href="/activities/create" class="btn-primary-custom" style="display:inline-flex;">
        <i class="bi bi-plus-lg"></i> Log Your First Activity
      </a>
    </div>

    <!-- Recent Table -->
    <div class="section-header" style="margin-top:8px;">
      <h2 class="section-title">Recent Workouts</h2>
      <span style="font-size:13px;color:var(--text-muted);">Last 10 entries</span>
    </div>

    <div class="table-container fade-in-up" style="margin-bottom:32px;">
      <table class="ft-table">
        <thead>
          <tr>
            <th>Activity</th>
            <th>Duration</th>
            <th>Calories</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="recentTbody">
          <tr>
            <td colspan="5" class="text-center" style="color:var(--text-muted);padding:40px;">
              <div class="skeleton" style="height:16px;width:60%;margin:0 auto;"></div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

  </main>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade modal-custom" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Delete Activity</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p style="color:var(--text-secondary);">Are you sure you want to delete this activity? This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-danger-custom" id="confirmDeleteBtn" style="padding:10px 20px;font-size:14px;">
          <i class="bi bi-trash-fill"></i> Delete Activity
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>


<%- include('partials/footer') %>
