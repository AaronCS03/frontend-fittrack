<%- include('partials/header', { title, API_BASE, activityId }) %>
<%
const page = 'details';
%>
<%- include('partials/navbar', { page }) %>

<div class="main-wrapper">
  <header class="top-navbar">
    <button class="hamburger-btn" id="hamburgerBtn"><i class="bi bi-list"></i></button>
    <span class="navbar-title">Activity Details</span>
    <div class="navbar-actions" style="margin-left:auto;display:flex;gap:10px;">
      <a href="/" class="btn-secondary-custom">
        <i class="bi bi-arrow-left"></i> Back
      </a>
    </div>
  </header>

  <main class="page-content" data-page="details">

    <!-- Hero card -->
    <div class="details-hero fade-in-up">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;">
        <div>
          <div style="font-size:13px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;font-weight:600;margin-bottom:10px;">
            Activity Details
          </div>
          <h1 style="font-size:36px;font-weight:800;color:var(--text-primary);margin-bottom:8px;" id="detailType">
            Loading…
          </h1>
          <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
            <span class="activity-type-badge" id="detailBadge"></span>
            <span style="color:var(--text-muted);font-size:14px;" id="detailDate"></span>
          </div>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="#" class="btn-secondary-custom" id="editBtn">
            <i class="bi bi-pencil-fill"></i> Edit
          </a>
          <button class="btn-danger-custom" style="padding:10px 18px;font-size:14px;" id="deleteBtn">
            <i class="bi bi-trash-fill"></i> Delete
          </button>
        </div>
      </div>
    </div>

    <!-- Stat summary cards -->
    <div class="details-grid stagger-children">
      <div class="detail-stat-card">
        <div style="font-size:32px;margin-bottom:8px;">⏱️</div>
        <div class="detail-stat-value" id="detailDuration">—</div>
        <div class="detail-stat-label">Minutes</div>
      </div>
      <div class="detail-stat-card">
        <div style="font-size:32px;margin-bottom:8px;">🔥</div>
        <div class="detail-stat-value" id="detailCalories">—</div>
        <div class="detail-stat-label">Calories Burned</div>
      </div>
      <div class="detail-stat-card">
        <div style="font-size:32px;margin-bottom:8px;">⚡</div>
        <div class="detail-stat-value" id="detailEfficiency">—</div>
        <div class="detail-stat-label">Cal / Min</div>
      </div>
    </div>

    <!-- Notes & Info -->
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:24px;" class="fade-in-up">

      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);padding:28px;">
        <h3 class="section-title" style="margin-bottom:20px;font-size:16px;">
          <i class="bi bi-journal-text text-green me-2"></i>Notes
        </h3>
        <p id="detailNotes" style="color:var(--text-secondary);font-size:15px;line-height:1.8;"></p>
      </div>

      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);padding:28px;">
        <h3 class="section-title" style="margin-bottom:20px;font-size:16px;">
          <i class="bi bi-bar-chart-fill text-blue me-2"></i>Intensity
        </h3>
        <canvas id="intensityChart" style="max-height:160px;"></canvas>
      </div>
    </div>

    <!-- Quick actions -->
    <div style="display:flex;gap:12px;flex-wrap:wrap;" class="fade-in-up">
      <a href="/activities/create" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Log Another Activity
      </a>
      <a href="/" class="btn-secondary-custom">
        <i class="bi bi-grid-1x2"></i> Back to Dashboard
      </a>
    </div>

  </main>
</div>

<!-- Delete Modal -->
<div class="modal fade modal-custom" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Delete Activity</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p style="color:var(--text-secondary);">Are you sure you want to delete this activity? This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-danger-custom" id="confirmDeleteBtn" style="padding:10px 20px;font-size:14px;">
          <i class="bi bi-trash-fill"></i> Delete Activity
        </button>
      </div>
    </div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>



<script>
// Mini gauge chart - se llama desde initDetails después de que los datos están listos
window.renderIntensityChart = function(dur, cal) {
  const canvas = document.getElementById('intensityChart');
  if (!canvas || !window.Chart) return;

  {
    const intensity = Math.min(100, Math.round((cal / Math.max(dur, 1)) * 10));

    new Chart(canvas, {
      type: 'doughnut',
      data: {
        datasets: [{
          data: [intensity, 100 - intensity],
          backgroundColor: ['#00f5a0', 'rgba(255,255,255,0.05)'],
          borderWidth: 0,
          hoverOffset: 0
        }]
      },
      options: {
        responsive: true,
        cutout: '72%',
        plugins: {
          legend: { display: false },
          tooltip: { enabled: false }
        },
        animation: { animateRotate: true, duration: 1200 }
      },
      plugins: [{
        id: 'centerText',
        beforeDraw(chart) {
          const { ctx, width, height } = chart;
          ctx.save();
          ctx.font = 'bold 22px Syne, sans-serif';
          ctx.fillStyle = '#00f5a0';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(intensity + '%', width / 2, height / 2);
          ctx.restore();
        }
      }]
    });
  }
};
</script>

<%- include('partials/footer') %>
