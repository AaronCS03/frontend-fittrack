      <div class="logo-icon">⚡</div>
      <span class="logo-text">Fit<span>Track</span></span>
    </a>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">Overview</div>
    <a href="/" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
